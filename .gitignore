# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
/build

# production
/dist
/.vercel

# misc
.DS_Store
*.pem
*.key
*.cert
*.crt
*.p12

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# aws specific (common for this tech stack)
.aws/
.ebextensions/
.elasticbeanstalk/

# typescript
*.tsbuildinfo
next-env.d.ts

# ide
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo

# os
Thumbs.db
Desktop.ini
