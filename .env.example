# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AWS Cognito
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=your-client-id
NEXT_PUBLIC_COGNITO_DOMAIN=your-domain.auth.us-east-1.amazoncognito.com

# AWS Services
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# DynamoDB
DYNAMODB_JOBS_TABLE=scrapeflow-jobs
DYNAMODB_USERS_TABLE=scrapeflow-users

# S3
S3_EXPORTS_BUCKET=scrapeflow-exports

# SQS
SQS_JOBS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT/scrapeflow-jobs

# Razorpay
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXX
RAZORPAY_KEY_SECRET=your-secret

# Secrets Manager
SECRETS_PROXY_ARN=arn:aws:secretsmanager:us-east-1:ACCOUNT:secret:proxy-creds
